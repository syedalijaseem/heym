# Database
# Optional override. Leave blank to auto-build from POSTGRES_* values.
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=6543
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=heym

# Credential encryption key (REQUIRED - auto-generated by run.sh/deploy.sh, or set manually)
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# JWT Authentication (REQUIRED - must be a cryptographically random value, min 32 chars)
# Generate one: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Backend
BACKEND_PORT=10105
ALLOW_REGISTER=true
DOCKER_LOGS_ENABLED=false
DOCKER_LOGS_ALLOWED_EMAILS=
REQUEST_BODY_MAX_SIZE_MB=100
TIMEZONE=Europe/Berlin

# Single-image runtime defaults
BACKEND_BIND_HOST=127.0.0.1
BACKEND_PROXY_HOST=127.0.0.1
AUTO_REWRITE_LOCAL_DATABASE_HOST=true

# Frontend
FRONTEND_PORT=4017
FRONTEND_URL=http://localhost:4017  # pragma: allowlist secret

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4017  # pragma: allowlist secret

# OpenTelemetry tracing (optional, disabled by default)
# When enabled, Heym emits a root span per workflow run and a child span per node
# over OTLP/HTTP. See docs: Reference > OpenTelemetry Tracing.
HEYM_OTEL_ENABLED=false
HEYM_OTEL_EXPORTER_OTLP_ENDPOINT=
HEYM_OTEL_EXPORTER_OTLP_HEADERS=
HEYM_OTEL_SERVICE_NAME=heym
HEYM_OTEL_TRACES_SAMPLER_RATIO=1.0
HEYM_OTEL_CAPTURE_NODE_IO=false
